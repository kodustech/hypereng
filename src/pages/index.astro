---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Phases from '../components/Phases.astro';
import Credentials from '../components/Credentials.astro';
import Framework from '../components/Framework.astro';
import Tools from '../components/Tools.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  title="Hyperengineering — AI SDLC Transformation"
  description="We embed Field Developer Engineers into your team to transform your software development lifecycle with AI."
  lang={lang}
>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Problem lang={lang} />
    <HowItWorks lang={lang} />
    <Phases lang={lang} />
    <Credentials lang={lang} />
    <Framework lang={lang} />
    <Tools lang={lang} />
    <CTA lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
