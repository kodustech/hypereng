---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="credentials" class="relative py-28 lg:py-40 overflow-hidden">
  <div class="hr-glow mb-28 lg:mb-40"></div>
  <div class="section-num">04</div>

  <!-- Decorative hexagon grid -->
  <svg class="absolute bottom-10 left-10 w-[250px] h-[250px] opacity-[0.04] pointer-events-none" viewBox="0 0 250 250" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon points="125,10 230,70 230,180 125,240 20,180 20,70" stroke="var(--color-accent)" stroke-width="0.8">
      <animateTransform attributeName="transform" type="rotate" from="0 125 125" to="360 125 125" dur="90s" repeatCount="indefinite" />
    </polygon>
    <polygon points="125,40 200,80 200,170 125,210 50,170 50,80" stroke="var(--color-accent)" stroke-width="0.5">
      <animateTransform attributeName="transform" type="rotate" from="360 125 125" to="0 125 125" dur="70s" repeatCount="indefinite" />
    </polygon>
    <polygon points="125,70 170,95 170,155 125,180 80,155 80,95" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.6">
      <animateTransform attributeName="transform" type="rotate" from="0 125 125" to="360 125 125" dur="50s" repeatCount="indefinite" />
    </polygon>
  </svg>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="reveal mb-6">
      <span class="tag">{t(lang, 'credentials.tag')}</span>
    </div>

    <h2 class="reveal reveal-delay-1 font-heading text-3xl sm:text-4xl lg:text-5xl font-800 leading-[1.05] tracking-[-0.02em] max-w-3xl mb-20 lg:mb-28">
      {t(lang, 'credentials.title')}
    </h2>

    <!-- Stats -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 md:grid-cols-3 gap-0 border border-border mb-16 lg:mb-24 relative">
      <svg class="absolute -top-2 -left-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 8V1h7"/></svg>
      <svg class="absolute -bottom-2 -right-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 23h7v-7"/></svg>

      <div class="p-8 lg:p-12 border-b md:border-b-0 md:border-r border-border text-center group hover:bg-bg-elevated transition-colors">
        <div class="stat-number text-6xl lg:text-8xl text-accent mb-3">{t(lang, 'credentials.stat1.number')}</div>
        <div class="text-sm text-text-secondary font-light">{t(lang, 'credentials.stat1.label')}</div>
      </div>
      <div class="p-8 lg:p-12 border-b md:border-b-0 md:border-r border-border text-center group hover:bg-bg-elevated transition-colors">
        <div class="stat-number text-6xl lg:text-8xl text-text mb-3">{t(lang, 'credentials.stat2.number')}</div>
        <div class="text-sm text-text-secondary font-light">{t(lang, 'credentials.stat2.label')}</div>
      </div>
      <div class="p-8 lg:p-12 text-center group hover:bg-bg-elevated transition-colors relative">
        <!-- Kodus glow -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity" style="background: radial-gradient(circle at center, var(--color-accent) 0%, transparent 70%); opacity: 0.03;"></div>
        <div class="relative">
          <div class="stat-number text-5xl lg:text-7xl text-accent mb-3">{t(lang, 'credentials.stat3.number')}</div>
          <div class="text-sm text-text-secondary font-light">{t(lang, 'credentials.stat3.label')}</div>
        </div>
      </div>
    </div>

    <!-- Text block -->
    <div class="reveal max-w-3xl mx-auto relative">
      <div class="absolute -left-6 lg:-left-10 top-0 bottom-0 w-[2px] bg-gradient-to-b from-accent via-accent/30 to-transparent"></div>
      <p class="text-lg lg:text-xl text-text-secondary leading-relaxed font-light pl-8 lg:pl-12">
        {t(lang, 'credentials.text')}
      </p>
    </div>
  </div>
</section>
