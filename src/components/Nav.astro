---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const otherLang = lang === 'en' ? 'pt' : 'en';
const otherLangUrl = lang === 'en' ? '/pt' : '/';
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a href={lang === 'en' ? '/' : '/pt'} class="group flex items-center gap-2">
      <span class="font-heading text-lg font-800 tracking-tight text-text">
        hyper<span class="text-accent">eng</span>
      </span>
    </a>

    <!-- Center links (desktop) -->
    <div class="hidden lg:flex items-center gap-1 px-3 py-1.5 border border-border rounded-none bg-bg/60 backdrop-blur-xl">
      <a href="#problem" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.problem')}</a>
      <span class="text-border">|</span>
      <a href="#how" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.how')}</a>
      <span class="text-border">|</span>
      <a href="#phases" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.phases')}</a>
      <span class="text-border">|</span>
      <a href="#credentials" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.credentials')}</a>
      <span class="text-border">|</span>
      <a href="#framework" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.framework')}</a>
      <span class="text-border">|</span>
      <a href="#tools" class="px-3 py-1.5 text-[0.65rem] font-mono uppercase tracking-[0.15em] text-text-tertiary hover:text-accent transition-colors">{t(lang, 'nav.tools')}</a>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href={otherLangUrl}
        class="text-[0.65rem] font-mono uppercase tracking-[0.15em] px-3 py-2 text-text-tertiary hover:text-accent transition-colors border border-transparent hover:border-border"
      >
        {otherLang.toUpperCase()}
      </a>
      <a
        href="#contact"
        class="hidden sm:inline-flex text-[0.65rem] font-mono uppercase tracking-[0.15em] px-5 py-2.5 bg-accent text-bg font-600 hover:bg-accent-hover transition-all"
      >
        {t(lang, 'nav.cta')}
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  });
</script>

<style>
  .nav-scrolled {
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid var(--color-border);
  }
</style>
