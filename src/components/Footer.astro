---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-border">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href={lang === 'en' ? '/' : '/pt'} class="font-heading text-sm font-800 tracking-tight text-text-tertiary hover:text-text transition-colors">
        hyper<span class="text-accent/60">eng</span>
      </a>

      <!-- Center -->
      <p class="text-[0.65rem] font-mono text-text-tertiary tracking-wider uppercase">
        {t(lang, 'footer.built')} <a href="https://kodus.io" target="_blank" rel="noopener" class="text-accent/60 hover:text-accent transition-colors">Kodus</a>
      </p>

      <!-- Right -->
      <p class="text-[0.65rem] font-mono text-text-tertiary tracking-wider">
        &copy; {new Date().getFullYear()} Hyperengineering. {t(lang, 'footer.rights')}
      </p>
    </div>
  </div>
</footer>
