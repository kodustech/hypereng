---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="problem" class="relative py-28 lg:py-40 overflow-hidden">
  <div class="section-num">01</div>

  <!-- Decorative SVG -->
  <svg class="absolute top-20 right-0 w-[300px] h-[300px] opacity-[0.06] pointer-events-none" viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="150" cy="150" r="140" stroke="var(--color-accent)" stroke-width="0.5" stroke-dasharray="4 6">
      <animateTransform attributeName="transform" type="rotate" from="0 150 150" to="360 150 150" dur="60s" repeatCount="indefinite" />
    </circle>
    <circle cx="150" cy="150" r="100" stroke="var(--color-accent)" stroke-width="0.5" stroke-dasharray="2 8">
      <animateTransform attributeName="transform" type="rotate" from="360 150 150" to="0 150 150" dur="45s" repeatCount="indefinite" />
    </circle>
    <circle cx="150" cy="150" r="60" stroke="var(--color-accent)" stroke-width="0.5" stroke-dasharray="6 4">
      <animateTransform attributeName="transform" type="rotate" from="0 150 150" to="360 150 150" dur="30s" repeatCount="indefinite" />
    </circle>
    <!-- Data points on orbits -->
    <circle r="3" fill="var(--color-accent)" opacity="0.6">
      <animateMotion dur="8s" repeatCount="indefinite" path="M150,10 A140,140 0 1,1 149,10 Z" />
    </circle>
    <circle r="2" fill="var(--color-accent)" opacity="0.4">
      <animateMotion dur="6s" repeatCount="indefinite" path="M150,50 A100,100 0 1,0 149,50 Z" />
    </circle>
  </svg>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="reveal mb-6">
      <span class="tag">{t(lang, 'problem.tag')}</span>
    </div>

    <h2 class="reveal reveal-delay-1 font-heading text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-800 leading-[1.05] tracking-[-0.02em] max-w-4xl mb-20 lg:mb-28">
      {t(lang, 'problem.title')}
    </h2>

    <!-- Stats row -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 md:grid-cols-3 gap-0 border border-border mb-20 lg:mb-28 relative">
      <!-- Animated corner brackets -->
      <svg class="absolute -top-2 -left-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 8V1h7"/></svg>
      <svg class="absolute -top-2 -right-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 1h7v7"/></svg>
      <svg class="absolute -bottom-2 -left-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 16v7h7"/></svg>
      <svg class="absolute -bottom-2 -right-2 w-6 h-6 text-accent opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 23h7v-7"/></svg>

      <!-- 88% -->
      <div class="p-8 lg:p-10 border-b md:border-b-0 md:border-r border-border group hover:bg-bg-elevated transition-colors">
        <div class="stat-number text-6xl lg:text-7xl text-text mb-3">{t(lang, 'problem.stat1.number')}</div>
        <div class="text-sm text-text-secondary mb-2 font-light">{t(lang, 'problem.stat1.label')}</div>
        <div class="text-[0.65rem] font-mono text-text-tertiary tracking-wider uppercase">{t(lang, 'problem.stat1.source')}</div>
      </div>

      <!-- 6% -->
      <div class="p-8 lg:p-10 border-b md:border-b-0 md:border-r border-border relative overflow-hidden group hover:bg-red-soft transition-colors">
        <div class="absolute inset-0 bg-red-soft"></div>
        <!-- Danger pulse -->
        <svg class="absolute top-4 right-4 w-5 h-5 text-red opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 9v4m0 4h.01M12 2L2 20h20L12 2z"/>
          <animate attributeName="opacity" values="0.2;0.6;0.2" dur="2s" repeatCount="indefinite" />
        </svg>
        <div class="relative">
          <div class="stat-number text-6xl lg:text-7xl text-red mb-3">{t(lang, 'problem.stat2.number')}</div>
          <div class="text-sm text-text-secondary mb-2 font-light">{t(lang, 'problem.stat2.label')}</div>
          <div class="text-[0.65rem] font-mono text-text-tertiary tracking-wider uppercase">{t(lang, 'problem.stat2.source')}</div>
        </div>
      </div>

      <!-- 3x -->
      <div class="p-8 lg:p-10 group hover:bg-bg-elevated transition-colors">
        <div class="stat-number text-6xl lg:text-7xl text-accent mb-3">{t(lang, 'problem.stat3.number')}</div>
        <div class="text-sm text-text-secondary mb-2 font-light">{t(lang, 'problem.stat3.label')}</div>
        <div class="text-[0.65rem] font-mono text-text-tertiary tracking-wider uppercase">{t(lang, 'problem.stat3.source')}</div>
      </div>
    </div>

    <!-- Two-column: insight + quote -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <div class="reveal relative">
        <!-- Decorative bracket -->
        <svg class="absolute -left-3 top-0 w-4 h-full opacity-20" viewBox="0 0 16 100" preserveAspectRatio="none" fill="none" stroke="var(--color-accent)" stroke-width="1">
          <path d="M16,0 L4,0 L4,100 L16,100" />
        </svg>
        <div class="pl-6">
          <div class="text-[0.65rem] font-mono uppercase tracking-[0.15em] text-accent mb-5">Insight</div>
          <p class="text-xl lg:text-2xl leading-relaxed text-text font-light">
            {t(lang, 'problem.insight')}
          </p>
          <div class="mt-4 text-xs font-mono text-text-tertiary">{t(lang, 'problem.insight.source')}</div>
        </div>
      </div>

      <div class="reveal reveal-delay-1 relative pl-8 border-l-2 border-red/40">
        <div class="big-quote relative">
          <p class="text-base lg:text-lg leading-relaxed text-text-secondary italic font-light">
            {t(lang, 'problem.quote')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
