---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const levels = [
  { level: 0, key: 'level0' as const, pct: 5 },
  { level: 1, key: 'level1' as const, pct: 25 },
  { level: 2, key: 'level2' as const, pct: 50 },
  { level: 3, key: 'level3' as const, pct: 75 },
  { level: 4, key: 'level4' as const, pct: 100 },
];
---

<section id="framework" class="relative py-28 lg:py-40 overflow-hidden">
  <div class="hr-glow mb-28 lg:mb-40"></div>

  <div class="section-num">05</div>

  <!-- Staircase SVG decoration -->
  <svg class="absolute left-10 bottom-[15%] w-[200px] h-[200px] opacity-[0.05] pointer-events-none" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,200 L0,160 L40,160 L40,120 L80,120 L80,80 L120,80 L120,40 L160,40 L160,0 L200,0" stroke="var(--color-accent)" stroke-width="1.5">
      <animate attributeName="stroke-dashoffset" from="600" to="0" dur="3s" fill="freeze" />
    </path>
    <circle cx="0" cy="200" r="3" fill="var(--color-accent)" opacity="0.3" />
    <circle cx="40" cy="160" r="3" fill="var(--color-accent)" opacity="0.4" />
    <circle cx="80" cy="120" r="3" fill="var(--color-accent)" opacity="0.5" />
    <circle cx="120" cy="80" r="3" fill="var(--color-accent)" opacity="0.6" />
    <circle cx="160" cy="40" r="3" fill="var(--color-accent)" opacity="0.7" />
    <circle cx="200" cy="0" r="4" fill="var(--color-accent)" opacity="0.9">
      <animate attributeName="r" values="3;6;3" dur="2s" repeatCount="indefinite" />
    </circle>
  </svg>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="reveal mb-6">
      <span class="tag">{t(lang, 'framework.tag')}</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-20 mb-20 lg:mb-28">
      <h2 class="reveal reveal-delay-1 font-heading text-3xl sm:text-4xl lg:text-5xl font-800 leading-[1.05] tracking-[-0.02em]">
        {t(lang, 'framework.title')}
      </h2>
      <p class="reveal reveal-delay-2 text-base lg:text-lg text-text-secondary leading-relaxed font-light self-end">
        {t(lang, 'framework.subtitle')}
      </p>
    </div>

    <!-- Maturity levels - staircase visualization -->
    <div class="reveal reveal-delay-2 space-y-0 mb-16 lg:mb-20">
      {levels.map((item) => {
        const isTop = item.level === 4;
        return (
          <div class={`group flex items-stretch border-x border-t last:border-b transition-colors duration-300 ${isTop ? 'border-accent/30 bg-accent/[0.04]' : 'border-border hover:bg-bg-elevated'}`}>
            {/* Level badge */}
            <div class={`w-16 lg:w-20 shrink-0 flex items-center justify-center border-r ${isTop ? 'border-accent/20 bg-accent/10' : 'border-border'}`}>
              <span class={`font-mono text-sm font-600 ${isTop ? 'text-accent' : 'text-text-tertiary'}`}>
                L{item.level}
              </span>
            </div>

            {/* Name */}
            <div class="w-32 lg:w-44 shrink-0 flex items-center px-4 lg:px-6 border-r border-border">
              <span class={`font-heading text-sm font-600 ${isTop ? 'text-accent' : 'text-text'}`}>
                {t(lang, `framework.${item.key}`)}
              </span>
            </div>

            {/* Description */}
            <div class="flex-1 flex items-center px-4 lg:px-6 py-4 lg:py-5">
              <p class="text-sm text-text-secondary font-light">{t(lang, `framework.${item.key}.desc`)}</p>
            </div>

            {/* Progress bar */}
            <div class="hidden md:flex w-32 lg:w-48 shrink-0 items-center px-4 lg:px-6 border-l border-border">
              <div class="w-full h-1 bg-border rounded-full overflow-hidden">
                <div
                  class={`h-full rounded-full transition-all duration-700 ${isTop ? 'bg-accent' : 'bg-text-tertiary'}`}
                  style={`width: ${item.pct}%`}
                ></div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="reveal text-center">
      <a
        href="https://www.aisdlc.io/"
        target="_blank"
        rel="noopener"
        class="btn-ghost"
      >
        <span>{t(lang, 'framework.cta')}</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </div>
  </div>
</section>
